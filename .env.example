# Copy to .env and fill in. NEVER commit .env (it is git-ignored).
# Keys are only required for the exchange(s) you actually trade on, and only
# for `mode: live`. Paper mode uses public market data and needs no keys.
#
# Security tips:
#  - Create API keys with TRADE permission only. NEVER enable withdrawals.
#  - Restrict keys to your IP where the exchange supports it.
#  - Start on the exchange testnet/sandbox before using real funds.

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Bybit ---
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- Coinbase (Advanced Trade) ---
COINBASE_API_KEY=
COINBASE_API_SECRET=
# Some Coinbase key types require a passphrase; leave blank if not applicable.
COINBASE_API_PASSWORD=
